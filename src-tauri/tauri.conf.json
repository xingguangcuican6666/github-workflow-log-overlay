{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitHub Workflow Log Overlay",
  "version": "0.1.0",
  "identifier": "dev.github-overlay.workflow-log",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Workflow Log Overlay",
        "label": "main",
        "width": 760,
        "height": 520,
        "minWidth": 360,
        "minHeight": 260,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "skipTaskbar": true,
        "center": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
